#!/usr/bin/env bash
set -euo pipefail

resolve_script_path() {
  local source_path="$1"
  while [ -L "$source_path" ]; do
    local dir target
    dir=$(cd -- "$(dirname -- "$source_path")" && pwd)
    target=$(readlink "$source_path")
    if [[ "$target" != /* ]]; then
      source_path="$dir/$target"
    else
      source_path="$target"
    fi
  done
  local final_dir
  final_dir=$(cd -- "$(dirname -- "$source_path")" && pwd)
  printf '%s/%s\n' "$final_dir" "$(basename -- "$source_path")"
}

resolved_script=$(resolve_script_path "${BASH_SOURCE[0]}")
SCRIPT_DIR=$(cd -- "$(dirname -- "$resolved_script")" && pwd)
REPO_ROOT=$(cd -- "$SCRIPT_DIR/.." && pwd)
TMP_BIN=$(mktemp "${TMPDIR:-/tmp}/foundry-cmgo-dev.XXXXXX")

cleanup() {
  rm -f "$TMP_BIN"
}
trap cleanup EXIT INT TERM

go -C "$REPO_ROOT" build -trimpath -o "$TMP_BIN" ./cmd/foundry-cmgo
"$TMP_BIN" "$@"
