package main

import (
	"bytes"
	"context"
	"flag"
	"fmt"
	"os"
	"strings"

	"{{.Module}}/pipeline"
	"{{.Module}}/processor"
	"github.com/palantir/palantir-compute-module-pipeline-search/pkg/foundry"
	foundryio "github.com/palantir/palantir-compute-module-pipeline-search/pkg/pipeline/io/foundry"
	localio "github.com/palantir/palantir-compute-module-pipeline-search/pkg/pipeline/io/local"
	"github.com/palantir/palantir-compute-module-pipeline-search/pkg/pipeline/worker"
)

func main() {
	ctx := context.Background()
	if len(os.Args) < 2 {
		usage(os.Stderr)
		os.Exit(2)
	}
	switch os.Args[1] {
	case "local":
		os.Exit(runLocal(ctx, os.Args[2:]))
	case "foundry":
		os.Exit(runFoundry(ctx, os.Args[2:]))
	case "help", "-h", "--help":
		usage(os.Stdout)
	default:
		_, _ = fmt.Fprintf(os.Stderr, "unknown command: %s\n", os.Args[1])
		usage(os.Stderr)
		os.Exit(2)
	}
}

func runLocal(ctx context.Context, args []string) int {
	fs := flag.NewFlagSet("local", flag.ContinueOnError)
	fs.SetOutput(os.Stderr)
	inputPath := fs.String("input", "data/input.csv", "Input CSV with an email column")
	outputPath := fs.String("output", "out/output.csv", "Output CSV path")
	workers := fs.Int("workers", 4, "Worker count")
	if err := fs.Parse(args); err != nil {
		return 2
	}

	emails, err := readInputEmails(*inputPath)
	if err != nil {
		_, _ = fmt.Fprintf(os.Stderr, "read input: %v\n", err)
		return 1
	}
	rows, err := process(ctx, emails, *workers)
	if err != nil {
		_, _ = fmt.Fprintf(os.Stderr, "process rows: %v\n", err)
		return 1
	}
	if err := os.MkdirAll(dirName(*outputPath), 0o755); err != nil {
		_, _ = fmt.Fprintf(os.Stderr, "create output dir: %v\n", err)
		return 1
	}
	out, err := os.Create(*outputPath)
	if err != nil {
		_, _ = fmt.Fprintf(os.Stderr, "create output: %v\n", err)
		return 1
	}
	defer func() { _ = out.Close() }()
	if err := pipeline.WriteCSV(out, rows); err != nil {
		_, _ = fmt.Fprintf(os.Stderr, "write output: %v\n", err)
		return 1
	}
	_, _ = fmt.Fprintf(os.Stdout, "wrote %d rows to %s\n", len(rows), *outputPath)
	return 0
}

func runFoundry(ctx context.Context, args []string) int {
	fs := flag.NewFlagSet("foundry", flag.ContinueOnError)
	fs.SetOutput(os.Stderr)
	inputAlias := fs.String("input-alias", "input", "Input alias in RESOURCE_ALIAS_MAP")
	outputAlias := fs.String("output-alias", "output", "Output alias in RESOURCE_ALIAS_MAP")
	outputFilename := fs.String("output-filename", "output.csv", "Dataset output filename")
	outputMode := fs.String("output-mode", "{{.OutputMode}}", "Output mode: dataset|stream")
	workers := fs.Int("workers", 4, "Worker count")
	if err := fs.Parse(args); err != nil {
		return 2
	}

	env, err := foundry.LoadEnv()
	if err != nil {
		_, _ = fmt.Fprintf(os.Stderr, "foundry env: %v\n", err)
		return 2
	}
	inputRef, ok := env.Aliases[*inputAlias]
	if !ok {
		_, _ = fmt.Fprintf(os.Stderr, "missing input alias %q\n", *inputAlias)
		return 2
	}
	outputRef, ok := env.Aliases[*outputAlias]
	if !ok {
		_, _ = fmt.Fprintf(os.Stderr, "missing output alias %q\n", *outputAlias)
		return 2
	}
	client, err := foundry.NewClient(env.Services.APIGateway, env.Services.StreamProxy, env.Token, env.DefaultCAPath)
	if err != nil {
		_, _ = fmt.Fprintf(os.Stderr, "foundry client: %v\n", err)
		return 2
	}

	emails, err := foundryio.ReadInputEmails(ctx, client, inputRef)
	if err != nil {
		_, _ = fmt.Fprintf(os.Stderr, "read foundry input: %v\n", err)
		return 1
	}
	rows, err := process(ctx, emails, *workers)
	if err != nil {
		_, _ = fmt.Fprintf(os.Stderr, "process rows: %v\n", err)
		return 1
	}

	switch strings.ToLower(strings.TrimSpace(*outputMode)) {
	case "dataset":
		var buf bytes.Buffer
		if err := pipeline.WriteCSV(&buf, rows); err != nil {
			_, _ = fmt.Fprintf(os.Stderr, "write csv: %v\n", err)
			return 1
		}
		if err := foundryio.UploadDatasetCSV(ctx, client, outputRef, *outputFilename, buf.Bytes()); err != nil {
			_, _ = fmt.Fprintf(os.Stderr, "upload dataset csv: %v\n", err)
			return 1
		}
	case "stream":
		for _, row := range rows {
			if err := foundryio.PublishJSONRecord(ctx, client, outputRef, pipeline.StreamRecord(row)); err != nil {
				_, _ = fmt.Fprintf(os.Stderr, "publish stream record: %v\n", err)
				return 1
			}
		}
	default:
		_, _ = fmt.Fprintf(os.Stderr, "invalid output mode %q\n", *outputMode)
		return 2
	}
	_, _ = fmt.Fprintf(os.Stdout, "processed %d foundry rows as %s\n", len(rows), *outputMode)
	return 0
}

func readInputEmails(path string) ([]string, error) {
	f, err := os.Open(path)
	if err != nil {
		return nil, err
	}
	defer func() { _ = f.Close() }()
	return localio.ReadEmailsCSV(f)
}

func process(ctx context.Context, emails []string, workers int) ([]pipeline.Row, error) {
	p := processor.Processor{}
	results, err := worker.ProcessAll(ctx, emails, p.Process, worker.Options{Workers: workers})
	if err != nil {
		return nil, err
	}
	rows := make([]pipeline.Row, 0, len(results))
	for _, result := range results {
		rows = append(rows, pipeline.RowFromResult(result.Output))
	}
	return rows, nil
}

func dirName(path string) string {
	idx := strings.LastIndex(path, string(os.PathSeparator))
	if idx < 0 {
		return "."
	}
	return path[:idx]
}

func usage(w *os.File) {
	_, _ = fmt.Fprint(w, `compute-module starter

Usage:
  compute-module local --input data/input.csv --output out/output.csv
  compute-module foundry --output-mode {{.OutputMode}}
`)
}
